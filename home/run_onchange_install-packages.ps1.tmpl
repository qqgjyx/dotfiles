{{- /* Profile-conditional package install — Windows.
       Re-runs when the rendered output of this template changes (i.e. when the
       profile or package list changes). Stage1 handles the core CLI stack +
       PSGallery modules; this script only adds dev/full profile scoop extras.
       PSGallery modules are NOT installed here because chezmoi spawns
       powershell with -NoProfile and on a fresh box PowerShellGet 1.0.0.1
       cannot bootstrap NuGet without the user session's full module path. */ -}}
# Profile: {{ .profile }}

$ErrorActionPreference = "Continue"

{{ if eq .profile "dev" -}}
# --- dev profile: Mosh + Tailscale -------------------------------------------
# Both fail to install via scoop in chezmoi's -NoProfile child:
#   mosh:      no scoop manifest exists (mosh is unix-side; use WSL on Windows)
#   tailscale: scoop install errors on Get-FileHash inside the -NoProfile child
#              shell ("URL is not valid" downstream noise is misleading)
# Print clear manual-install pointers instead of attempting and failing.
Write-Host "dev profile (Windows): mosh + tailscale must be installed manually:"
Write-Host "  - mosh:      run from WSL (e.g. 'wsl sudo apt install mosh')"
Write-Host "  - tailscale: https://tailscale.com/download/windows"
{{- end }}

{{ if eq .profile "full" -}}
# --- full profile: power-user CLI extras -------------------------------------
# Map scoop package -> binary name (often the same; ripgrep ships as `rg`).
$fullCliPkgs = @{
    "fd"      = "fd"
    "ripgrep" = "rg"
    "fzf"     = "fzf"
    "delta"   = "delta"
    "atuin"   = "atuin"
}
foreach ($pkg in $fullCliPkgs.Keys) {
    if (Get-Command $fullCliPkgs[$pkg] -ErrorAction SilentlyContinue) {
        Write-Host "✓ $pkg"
    } else {
        Write-Host "==> scoop install $pkg"
        scoop install $pkg
    }
}

# --- full profile: TeX Live (basic) + Clash Verge (GUI installer) -----------
if (-not (Get-Command latex -ErrorAction SilentlyContinue)) {
    Write-Host "==> scoop install miktex"
    scoop install miktex
}
if (-not (Get-Command clash-verge -ErrorAction SilentlyContinue)) {
    Write-Warning "Clash Verge: install manually from https://github.com/clash-verge-rev/clash-verge-rev/releases (no scoop manifest)."
}
{{- end }}
