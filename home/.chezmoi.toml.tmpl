{{- /*
    .chezmoi.toml.tmpl — runs once on `chezmoi init` to generate
    ~/.config/chezmoi/chezmoi.toml for this machine. Prompts for name,
    email, install profile.
*/ -}}

{{- $name    := promptStringOnce . "name"    "Name"  "Juntang" -}}
{{- $email   := promptStringOnce . "email"   "Email" "150919274+qqgjyx@users.noreply.github.com" -}}
{{- $profile := promptStringOnce . "profile" "Install profile (core|dev|full)" "core" -}}

# Persist the source directory so plain `chezmoi diff/verify/apply` work
# after bootstrap. stage2 passes --source as a one-shot CLI flag; without
# this, chezmoi falls back to ~/.local/share/chezmoi which doesn't exist.
sourceDir = {{ joinPath .chezmoi.homeDir "dotfiles" | quote }}

[data]
    name    = {{ $name    | quote }}
    email   = {{ $email   | quote }}
    profile = {{ $profile | quote }}
{{ if eq .chezmoi.os "windows" }}
# chezmoi spawns powershell.exe as a child for .ps1 run_onchange scripts;
# the child inherits Machine-scope execution policy, which is Restricted on
# many locked-down boxes. Bypass scoped to chezmoi-invoked scripts only.
[interpreters.ps1]
    command = "powershell"
    args    = ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]
{{- end }}
