{{- /* POSIX Cursor install — mirror settings to the OS-specific Cursor User dir
       (canonical lives at ~/.config/Cursor/User; macOS needs ~/Library copy),
       then install extensions for the active profile. */ -}}
#!/usr/bin/env bash
set -euo pipefail

CANONICAL="$HOME/.config/Cursor/User"
{{ if eq .chezmoi.os "darwin" -}}
TARGET="$HOME/Library/Application Support/Cursor/User"
{{- else -}}
TARGET="$CANONICAL"
{{- end }}

mkdir -p "$TARGET"
if [ "$CANONICAL" != "$TARGET" ]; then
    for f in settings.json keybindings.json; do
        [ -f "$CANONICAL/$f" ] && cp -f "$CANONICAL/$f" "$TARGET/$f"
    done
fi

if ! command -v cursor >/dev/null 2>&1; then
    echo "cursor CLI not on PATH - install Cursor and re-run 'chezmoi apply'." >&2
    exit 0
fi

while IFS= read -r ext; do
    [ -n "$ext" ] && cursor --install-extension "$ext"
done <<'EOF'
{{- range .cursor.extensions.base }}
{{ . }}
{{- end }}
{{- if eq .profile "full" }}{{- range .cursor.extensions.full }}
{{ . }}
{{- end }}{{- end }}
EOF
