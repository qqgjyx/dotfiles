{{- /* Windows Cursor install — mirror canonical settings to %APPDATA%\Cursor\User,
       then install extensions for the active profile. */ -}}
$ErrorActionPreference = "Stop"

$Canonical = Join-Path $HOME ".config\Cursor\User"
$Target    = Join-Path $env:APPDATA "Cursor\User"

New-Item -ItemType Directory -Force -Path $Target | Out-Null
foreach ($f in "settings.json", "keybindings.json") {
    $src = Join-Path $Canonical $f
    if (Test-Path $src) { Copy-Item -Force $src (Join-Path $Target $f) }
}

if (-not (Get-Command cursor -ErrorAction SilentlyContinue)) {
    Write-Warning "cursor CLI not on PATH - install Cursor and re-run 'chezmoi apply'."
    return
}

@'
{{- range .cursor.extensions.base }}
{{ . }}
{{- end }}
{{- if eq .profile "full" }}{{- range .cursor.extensions.full }}
{{ . }}
{{- end }}{{- end }}
'@ -split "`n" | Where-Object { $_ } | ForEach-Object { & cursor --install-extension $_ }
